@page "/ThisOrThat/Leaderboard"
@using TheCrewCommunity.Services
@using TheCrewCommunity.Data.Entities.GameData.Motorfest
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject GeneralUtils GeneralUtils
@inject IThisOrThatLeaderboardService LeaderboardService
@inject NavigationManager NavigationManager
@inject IHttpContextAccessor HttpContextAccessor
@inject IDatabaseMethodService DatabaseMethodService
@rendermode InteractiveServer
<HeadContent>
    <meta property="og:title" content="This or That Leaderboard" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="@NavigationManager.Uri" />
    <meta property="og:image" content="" />
    <meta property="og:description" content="@GetTop5VehiclesDescription()" />
</HeadContent>
<div class="header-container">
    <div class="header-content">
        <h1 class="main-title">This or That Leaderboard</h1>
        <div class="controls-container">
            <div class="search-wrapper">
                <input type="text" class="search-box" placeholder="Search" @bind-value="_searchText" @bind-value:event="oninput"/>
                @if (!string.IsNullOrEmpty(_searchText))
                {
                    <button class="clear-search-button" @onclick="() => _searchText = string.Empty">✖</button>
                }
                <i class="search-icon">🔍</i>
            </div>
        </div>
    </div>
</div>
<div class="content-layout">
    <div class="table-container">
        <table class="table">
            <thead>
            <tr>
                <th @onclick="() => SetSortMode(SortMode.V2)" style="cursor: pointer;">Rank</th>
                <th style="width: 100%">Vehicle</th>
                <th>Total Wins</th>
                <th>Points</th>
                <th class="implementation-header">In Game</th>
                <th class="table-image-column">Thumbnail</th>
            </tr>
            </thead>
            <tbody>
            @if (FilteredEntries == null)
            {
                <tr>
                    <td colspan="6">Loading...</td>
                </tr>
            }
            else
            {
                <Virtualize Items="@FilteredEntries" Context="entry" ItemSize="50" OverscanCount="20">
                    <tr class="table-row @(_selectedEntry == entry ? "selected-row" : "")" @onclick="() => SelectEntry(entry)">
                        <td class="rank-cell @GetRankClass(entry.V2Rank)">
                            <img src="@GetRankMedal(entry.V2Rank)" class="rank-medal" alt="Rank Medal"/>
                            @if (entry.V2Rank != 1)
                            {
                                <span class="rank-number">@entry.V2Rank</span>
                            }
                        </td>
                        <td>@entry.VehicleSuggestion.Brand - @entry.VehicleSuggestion.Model - @entry.VehicleSuggestion.Year</td>
                        <td>@entry.TotalWins</td>
                        <td>@entry.V2Points</td>
                        <td class="implementation-cell">
                            @if (entry.VehicleSuggestion.Implementations != null && entry.VehicleSuggestion.Implementations.Count > 0)
                            {
                                string hoverText = string.Join("\n", entry.VehicleSuggestion.Implementations.Select(i => (i.Brand?.Name ?? "") + " " + i.ModelName + " (" + i.Year.Year + ")"));
                                <div class="implementation-wrapper" title="@hoverText">
                                    <img src="assets/Icons/motorfest_logo.png" class="motorfest-icon" alt="In Game"/>
                                    @if (entry.VehicleSuggestion.Implementations.Count > 1)
                                    {
                                        <span class="implementation-count">@entry.VehicleSuggestion.Implementations.Count</span>
                                    }
                                </div>
                            }
                        </td>
                        <td class="thumbnail-cell"><img src="https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/@entry.VehicleSuggestion.ImageId/leaderboardThumb" alt="@entry.VehicleSuggestion.Brand - @entry.VehicleSuggestion.Model - @entry.VehicleSuggestion.Year"/></td>
                    </tr>
                </Virtualize>
            }
            </tbody>
        </table>
    </div>
    <div class="preview-container">
        @if (_selectedEntry != null)
        {
            <img class="preview-image selected-preview" src="https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/@_selectedEntry.VehicleSuggestion.ImageId/public" alt="@_selectedEntry.VehicleSuggestion.Brand - @_selectedEntry.VehicleSuggestion.Model - @_selectedEntry.VehicleSuggestion.Year"/>
            <AuthorizeView Roles="Administrator">
                <div class="link-vehicle-section">
                    <h3 class="section-subtitle">Link to Motorfest Vehicle</h3>
                    <div class="form-group">
                        <div class="input-group">
                            <input list="motorfest-vehicles-list" class="form-control" @bind-value="_motorfestVehicleName" @bind-value:event="oninput" @onchange="OnMotorfestVehicleChanged" placeholder="SELECT MOTORFEST VEHICLE" />
                            <datalist id="motorfest-vehicles-list">
                                @if (_motorfestVehicles != null)
                                {
                                    @foreach (var vehicle in _motorfestVehicles)
                                    {
                                        <option value="@(vehicle.Brand.Name + " " + vehicle.ModelName + " (" + vehicle.Year.Year + ")")" />
                                    }
                                }
                            </datalist>
                        </div>
                    </div>
                    <button class="upload-button" @onclick="LinkVehicle" disabled="@(_selectedMotorfestVehicleId == null || _isLinking)">
                        @if (_isLinking)
                        {
                            <i class="fa fa-spinner fa-spin"></i> <span>LINKING...</span>
                        }
                        else
                        {
                            <span>LINK VEHICLE</span>
                        }
                    </button>
                    @if (!string.IsNullOrEmpty(_linkErrorMessage))
                    {
                        <div class="error-message">@_linkErrorMessage</div>
                    }
                </div>
            </AuthorizeView>
        }
    </div>
</div>
@if (!_isMobile)
{
    <GoogleAdSense AdsFormat="horizontal" Slot="8708810204" Style="display:inline-block;width:700px;height:100px" FullWidthResponsive="false"/>
}

@code {
    private enum SortMode
    {
        V1,
        V2
    }
    
    private SortMode _currentSortMode = SortMode.V2;
    TimeSpan UntilRefresh { get; set; }
    List<ThisOrThatLeaderboardService.LeaderboardEntry>? _leaderboardEntries;
    ThisOrThatLeaderboardService.LeaderboardEntry? _selectedEntry;
    string _searchText = "";
    bool _isMobile = false;

    private List<MotorfestVehicle>? _motorfestVehicles;
    private string _motorfestVehicleName = string.Empty;
    private Guid? _selectedMotorfestVehicleId;
    private bool _isLinking = false;
    private string? _linkErrorMessage;

    private void SetSortMode(SortMode mode)
    {
        _currentSortMode = mode;
    }

    private string GetSortIndicator(SortMode mode)
    {
        return _currentSortMode == mode ? "▼" : "";
    }
    
    List<ThisOrThatLeaderboardService.LeaderboardEntry>? FilteredEntries
    {
        get
        {
            if (_leaderboardEntries is null) return null;
            if (string.IsNullOrWhiteSpace(_searchText))
            {
                return _currentSortMode switch
                {
                    SortMode.V1 => _leaderboardEntries
                        .OrderByDescending(entry => entry.WinRatio)
                        .ThenByDescending(entry => entry.TotalWins)
                        .ToList(),
                    SortMode.V2 => _leaderboardEntries
                        .OrderByDescending(entry => entry.V2Points)
                        .ToList(),
                    _ => _leaderboardEntries
                };
            }
                var query = _leaderboardEntries
                .Select(entry => new
                {
                    Entry = entry,
                    FullName = $"{entry.VehicleSuggestion.Brand} {entry.VehicleSuggestion.Model} {entry.VehicleSuggestion.Year}",
                    Similarity = GeneralUtils.CalculateStringSimilarity(
                        _searchText.AsSpan(),
                        $"{entry.VehicleSuggestion.Brand} {entry.VehicleSuggestion.Model} {entry.VehicleSuggestion.Year}".AsSpan()
                    )
                })
                .OrderByDescending(x => x.Similarity);

            if (_currentSortMode == SortMode.V1)
            {
                return query
                    .ThenByDescending(x => x.Entry.WinRatio)
                    .ThenByDescending(x => x.Entry.TotalWins)
                    .Select(x => x.Entry)
                    .ToList();
            }
            return query
                .ThenByDescending(x => x.Entry.V2Points)
                .Select(x => x.Entry)
                .ToList();
        }
    }


    private void SelectEntry(ThisOrThatLeaderboardService.LeaderboardEntry entry)
    {
        if (_selectedEntry == entry)
        {
            _selectedEntry = null;
            return;
        }
        _selectedEntry = entry;
        _motorfestVehicleName = string.Empty;
        _selectedMotorfestVehicleId = null;
        _linkErrorMessage = null;
    }

    private void OnMotorfestVehicleChanged()
    {
        var selected = _motorfestVehicles?.FirstOrDefault(v => (v.Brand.Name + " " + v.ModelName + " (" + v.Year.Year + ")") == _motorfestVehicleName);
        _selectedMotorfestVehicleId = selected?.Id;
    }

    private async Task LinkVehicle()
    {
        if (_selectedEntry == null || _selectedMotorfestVehicleId == null) return;
        _isLinking = true;
        _linkErrorMessage = null;
        try
        {
            await DatabaseMethodService.LinkSuggestionToVehicleAsync(_selectedEntry.VehicleSuggestion.Id, _selectedMotorfestVehicleId.Value);
            await LeaderboardService.UpdateLeaderboardAsync();
            _leaderboardEntries = LeaderboardService.GetLeaderboard();
            _selectedEntry = _leaderboardEntries.FirstOrDefault(e => e.VehicleSuggestion.Id == _selectedEntry.VehicleSuggestion.Id);
            _motorfestVehicleName = string.Empty;
            _selectedMotorfestVehicleId = null;
        }
        catch (Exception ex)
        {
            _linkErrorMessage = "Failed to link vehicle: " + ex.Message;
        }
        finally
        {
            _isLinking = false;
        }
    }

    private string GetRankClass(int rank)
    {
        return rank switch
        {
            1 => "rank-legend",
            <= 3 => "rank-platinum",
            <= 10 => "rank-gold",
            <= 25 => "rank-silver",
            _ => "rank-bronze"
        };
    }

    private string GetRankMedal(int rank)
    {
        return rank switch
        {
            1 => "assets/PVP_Medals/GR_Legend.png",
            <= 3 => "assets/PVP_Medals/GR_Platinum.png",
            <= 10 => "assets/PVP_Medals/GR_Gold.png",
            <= 25 => "assets/PVP_Medals/GR_Silver.png",
            _ => "assets/PVP_Medals/GR_Bronze.png"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        _leaderboardEntries = LeaderboardService.GetLeaderboard();
        UntilRefresh = LeaderboardService.GetNextRefreshTime() - DateTime.Now;
        
        var userAgent = HttpContextAccessor?.HttpContext?.Request.Headers["User-Agent"].ToString();
        if (userAgent != null && (userAgent.Contains("Android") || userAgent.Contains("iPhone")))
        {
            _isMobile = true;
        }
        _motorfestVehicles = await DatabaseMethodService.GetMotorfestVehiclesAsync();
    }

    private string GetTop5VehiclesDescription()
    {
        return $"Top 5 vehicles: {string.Join(", ", FilteredEntries?.Take(5).Select(x => $"{x.VehicleSuggestion.Brand} {x.VehicleSuggestion.Model} {x.VehicleSuggestion.Year}"))}";
    }
}