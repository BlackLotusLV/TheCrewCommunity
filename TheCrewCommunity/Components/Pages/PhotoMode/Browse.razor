@page "/PhotoMode/Browse"
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Caching.Memory
@using TheCrewCommunity.Data
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using TheCrewCommunity.Data.Entities.GameData
@using TheCrewCommunity.Services
@inject IDbContextFactory<LiveBotDbContext> DbContextFactory
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager
@inject ILogger<Browse> Logger
@inject IMemoryCache Cache
@rendermode InteractiveServer

<PageTitle>Browsing Images</PageTitle>

<div class="browse-container">
    <header class="browse-header">
        <h1 class="page-title">Browsing Images</h1>
        <div class="filters-group">
            <select class="filter-select" value="@_selectedGameId" @onchange="OnGameSelected">
                <option value="@Guid.Empty">All Games</option>
                @foreach (Game game in _games!)
                {
                    <option value="@game.Id">@game.Name</option>
                }
            </select>
            <select class="filter-select" value="@_selectedSortMode" @onchange="OnSortModeSelectedAsync">
                @foreach (SortMode option in Enum.GetValues(typeof(SortMode)))
                {
                    <option value="@option">@(GetEnumName(option))</option>
                }
            </select>
        </div>
    </header>

    @if (_topHotImages.Length > 0)
    {
        <section class="top-hot-section">
            <h2 class="section-title">
                <span class="oi oi-fire" aria-hidden="true"></span> Top 5 Hot
            </h2>
            <div class="top-hot-grid">
                @foreach (var img in _topHotImages)
                {
                    <div class="hot-image-card" @onclick="@(_ => OpenImage(img.Id))">
                        <img src="@($"https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/{img.Id}/Thumbnail")" alt="@img.Id" />
                        <div class="author-overlay">
                            <a href="Account/Profile/@(img.ApplicationUser?.Id ?? Guid.Empty)" @onclick:stopPropagation="true">
                                @img.ApplicationUser?.GlobalUsername
                            </a>
                        </div>
                        <div class="hot-badge">
                            🔥 HOT
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <section class="main-grid-section">
        <h2 class="section-title">All Images</h2>
        <div class="image-grid">
            @for (var i = 0; i < _currentLoadEnd; i++)
            {
                if (i >= _images.Length) break;
                Guid id = _images[i].Id;
                Game game = _images[i].Game!;
                <div class="image-container" @onclick='@(_ => OpenImage(id))'>
                    <img class="image-thumb" src="@($"https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/{id}/Thumbnail")" alt="@id" />
                    <div class="author-overlay">
                        <a href="Account/Profile/@(_images[i].ApplicationUser?.Id ?? Guid.Empty)" @onclick:stopPropagation="true">
                            @_images[i].ApplicationUser?.GlobalUsername
                        </a>
                    </div>
                    <img class="game-logo" src="assets/Icons/@game.IconFile" alt="@game.Name logo" />
                </div>
            }
        </div>
    </section>

    <div class="load-more">
        @if (_isLoading)
        {
            <p>Loading images...</p>
        }
        else if (_currentLoadEnd >= _images.Length && _images.Length > 0)
        {
            <p>All images loaded</p>
        }
        else if (_images.Length > 0)
        {
            <button class="load-more-button" @ref="_loadMoreButton" @onclick="LoadMoreImages">Load more</button>
        }
    </div>

    @if (_selectedImage != null)
    {
        <div class="lightbox-overlay" @onclick="CloseImage">
            <div class="lightbox-content @(_navigatedOnce ? "navigating-once" : "")" @onclick:stopPropagation="true">
                <button class="close-button" @onclick="CloseImage">
                    <i class="fas fa-times"></i>
                </button>
                
                <div class="lightbox-main">
                    @if (_selectedImageIndex > 0)
                    {
                        <div class="nav-preview prev" @onclick="PreviousImage">
                            <img src="@($"https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/{_images[_selectedImageIndex - 1].Id}/public")" alt="Previous" />
                        </div>
                    }

                        <div class="image-wrapper @(_isNavigating ? "navigating " + _navigationDirection : "")">
                            @for (int i = Math.Max(0, _selectedImageIndex - 2); i <= Math.Min(_images.Length - 1, _selectedImageIndex + 2); i++)
                            {
                                var localId = _images[i].Id;
                                var localIndex = i;
                                string imgClass = localIndex == _selectedImageIndex ? "active" : "preload";
                                if (_isNavigating)
                                {
                                    if (_navigationDirection == "next" && localIndex == _selectedImageIndex - 1) imgClass = "outgoing";
                                    else if (_navigationDirection == "prev" && localIndex == _selectedImageIndex + 1) imgClass = "outgoing";
                                }
                                <img @key="localId" src="@($"https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/{localId}/public")" class="@imgClass" alt="Image @localIndex" />
                            }
                        </div>

                    @if (_selectedImageIndex < _images.Length - 1)
                    {
                        <div class="nav-preview next" @onclick="NextImage">
                            <img src="@($"https://imagedelivery.net/Gym1gfQYlAl-qmVmCPEnkA/{_images[_selectedImageIndex + 1].Id}/public")" alt="Next" />
                        </div>
                    }
                </div>
                
                <div class="lightbox-footer">
                    <div class="image-info">
                        <h3 class="image-title">@_selectedImage.Title</h3>
                        <p class="image-author">By <a href="Account/Profile/@(_selectedImage.ApplicationUser?.Id ?? Guid.Empty)">@_selectedImage.ApplicationUser?.GlobalUsername</a></p>
                    </div>
                    <div class="image-actions">
                        <button class="action-button" @onclick="CopyImageUrl" title="Copy Image URL">
                            <i class="fas fa-copy"></i>
                        </button>
                        @if (_canDelete)
                        {
                            <button class="action-button delete" @onclick="() => _showDeleteConfirm = true" title="Delete Image">
                                <i class="fas fa-trash"></i>
                            </button>
                        }
                        <div class="likes-container">
                            <span class="likes-count">@_likesCount</span>
                            <button class="like-button @(_isLiked ? "liked" : "")" @onclick="ToggleLikeAsync" title="@(_currentUser == null ? "Log in to like" : "Like")">
                                <i class="fas fa-heart"></i>
                            </button>
                        </div>
                        @if (_selectedImage.Game != null)
                        {
                            <img class="footer-game-logo" src="assets/Icons/@_selectedImage.Game.IconFile" alt="@_selectedImage.Game.Name" />
                        }
                    </div>
                </div>
            </div>
        </div>
        @if (_showDeleteConfirm)
        {
            <div class="modal-overlay" @onclick="() => _showDeleteConfirm = false">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <h3>Confirm Delete</h3>
                    <p>Are you sure you want to delete this image? This action cannot be undone.</p>
                    <div class="modal-buttons">
                        <button class="modal-button cancel" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                        <button class="modal-button delete" @onclick="DeleteImageAsync">Delete</button>
                    </div>
                </div>
            </div>
        }
    }
</div>
@code {

    

}
<script>
    function InitInfiniteScroll(dotnetHelper,loadMoreButton) {
        let options={
        root: null,
        rootMargin: '0px',
        threshold: 1.0
        }
        let observer = new IntersectionObserver(function (entries, observer){
            entries.forEach(entry=>{
                if (entry.isIntersecting){
                    dotnetHelper.invokeMethodAsync('LoadMoreImages');
                }
            })
        }, options);
        observer.observe(loadMoreButton);
    }
    function applyOnLoadToImages() {
        let images = document.querySelectorAll('.image-grid img.image-thumb');
        console.log('Iterating on all images');
        images.forEach(function(img) {
            // remove the processed-image class if it is present
            if (img.classList.contains('processed-image')) {
                img.classList.remove('processed-image');
            }

            // remove the vertical-image class from the image parent node if it is present
            if (img.parentNode.classList.contains('vertical-image')) {
                img.parentNode.classList.remove('vertical-image');
            }
            img.onload = function() {
                if (img.naturalHeight > img.naturalWidth) {
                    img.parentNode.classList.add('vertical-image');
                    console.log('Added vertical image class to image');
                }
                img.classList.add('processed-image');
                console.log('added processed-image')
                img.onload = null;
            };
            // This forces the onload event if the image is loaded from the cache
            if (img.complete) {
                img.onload();
            }
        });
    }
    function OnLoad() {
        applyOnLoadToImages();
    }

</script>